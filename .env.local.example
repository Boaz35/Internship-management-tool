# Supabase — copy to .env.local and fill in from your Supabase project settings.
# Do NOT put real values in this example file (it can be committed to git).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY

# Server-only key (Supabase → Settings → API → secret key, starts with sb_secret_).
# NEVER expose this to the browser and NEVER commit the real value.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SECRET_KEY

# The Google Workspace domain allowed to sign in (e.g. zemingo.com).
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=zemingo.com

# Public site URL, used to build the OAuth redirect. In prod set to your Vercel URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
